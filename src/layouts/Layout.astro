	<body>
		<slot />
		<style is:global>
			:root {
				--azul: #344754;
				--azulOpa: #34475480;
				--azulDarker: #344754e3;
				--pastel: #eadfd4;
				--pastelOpa: #eadfd480;
				--amarillo: #f3ba74;
				--amarilloOpa: #f3ba7480;
				--gris: #d1cdc5;
				--grisOpa: #d1cdc580;

				--titles: 5rem;
				--subTitles: 3rem;
				--subTitles2: 2rem;
				--parrafos: 1.6rem;
				--footer: 1.2rem;

				font-family: 'Raleway';
				background-color: var(--azul);
				font-size: 62.5%;
				scroll-behavior: smooth;
			}

			@font-face {
				font-family: 'Raleway';
				src: local(''), url('/fonts/Raleway-VariableFont_wght.ttf') format('ttf');
			}
			@font-face {
				font-family: 'Raleway Italic';
				src: local(''), url('/fonts/Raleway-Italic-VariableFont_wght.ttf') format('ttf');
			}

			body {
				/* overflow: overlay; */
				max-width: 100%;
				height: 100vh;
				/* overflow-x: hidden; */
			}

			.scrollLock {
				overflow: hidden;
			}

			::-webkit-scrollbar {
				width: 0.5rem;
				margin-right: 0.5rem;
			}

			::-webkit-scrollbar-thumb {
				-webkit-border-radius: 5px;
				border-radius: 5px;
				background: var(--pastel);
			}
			::-webkit-scrollbar-thumb:window-inactive {
				background: var(--gris);
			}

			@media (min-width: 1281px) {
				:root {
					--titles: 10rem;
					--subTitles: 4rem;
					--subTitles2: 3rem;
					--parrafos: 1.8rem;
					--footer: 1.6rem;
				}
			}
		</style>
