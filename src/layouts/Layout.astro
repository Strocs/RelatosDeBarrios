		<meta name='audience' content='all' />
		<meta
			name='description'
			content='Relatos de Barrios busca difundir el valor patrimonial e histórico de éste y otros barrios de La Serena ligados al patrimonio industrial, destacando la experiencia social y patrimonial detrás de la vida de sus habitantes.'
		/>
		<meta name='keywords' content='patrimonio, la serena, arquitectura' />
		<meta name='robots' content='index, nofollow' />
		<title>Relatos de Barrios | Conjunto Habitacional Rengifo</title>
