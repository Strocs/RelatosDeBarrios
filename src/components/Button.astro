---
export interface Props {
	className: string
	text: string
	href: string
}

const { className, text, href } = Astro.props
---

<a href={href} target='_blank' class={className}>
	<p>{text}</p>
</a>

<style>
	a {
		background-color: transparent;
		border: solid 0.15em white;
		border-radius: 0.8rem;
		color: white;
		font-size: var(--parrafos);
		letter-spacing: 0.5px;
		text-decoration: none;
		transition: color 200ms ease, background 300ms ease;
	}
	
  a:hover {
		color: var(--azul);
		background: white;
		transition: color 200ms ease, background 300ms ease;
	}

	p {
		margin: 0.3em 1em;
		font-weight: 600;
	}
</style>
